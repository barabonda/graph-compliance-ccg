# Frontend (Next.js) environment — copy to .env.local and fill real values.
# .env.local is gitignored; never commit secrets, never prefix these NEXT_PUBLIC_.

# Mac mini LLM server (OpenAI-compatible). Used server-side by
# src/app/api/chat/route.ts. Also set these in Vercel → Settings → Environment
# Variables for the deployed app.
LLM_BASE_URL=https://mac-mini-m4-llm.tail023e97.ts.net
LLM_API_KEY=<team-provided-key>

# FastAPI review backend the dev server proxies /api/* and /health to.
# CCG_API_BASE=http://localhost:8770
