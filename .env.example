OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic Claude provider (selected when llm_model starts with claude-*) ---
# The review API still keeps OpenAI/local as the default; set this key only when
# using Claude models from the console dropdown or CCG_*_MODEL env overrides.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
CCG_ANTHROPIC_TIMEOUT_SECONDS=180
CCG_ANTHROPIC_MAX_RETRIES=1
CCG_ANTHROPIC_MAX_OUTPUT_TOKENS=20000

# --- Local LLM toggle (OpenAI-compatible Chat Completions, e.g. Ollama) ---
# Leave LLM_BASE_URL empty to use the cloud OpenAI Responses path (default).
# Set it to route LLM calls to a local/self-hosted endpoint instead.
# Ollama on Tailscale example (hostname; fall back to IP 100.103.82.56 if DNS fails):
#   LLM_BASE_URL=http://mac-mini-m4-llm.tail023e97.ts.net:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL=ax-4.0-light   # or midm-2.0-base / exaone4-32b / qwen3.5:9b / gemma4
LLM_BASE_URL=
LLM_API_KEY=ollama
LLM_MODEL=ax-4.0-light

# Per-request local endpoint: even in cloud-default mode, selecting a local model
# tag (ax-4.0-light / midm-2.0-base / exaone4-32b / qwen3.5:9b / gemma4) routes to
# this endpoint instead of OpenAI. Leave empty to disable local model selection.
LOCAL_LLM_BASE_URL=http://mac-mini-m4-llm.tail023e97.ts.net:11434/v1
LOCAL_LLM_API_KEY=ollama

NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# Optional CU candidate rerank stage before LLM rerank.
# Requires: pip install FlagEmbedding
CCG_ENABLE_CROSS_ENCODER_RERANKER=false
CCG_CROSS_ENCODER_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CCG_CROSS_ENCODER_USE_FP16=true
